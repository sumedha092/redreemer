PORT=3001

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Gemini
GEMINI_API_KEY=AIzaSy...
# Optional; default gemini-2.0-flash. Use gemini-1.5-flash if your key rejects newer models.
# GEMINI_MODEL=gemini-1.5-flash

# ElevenLabs (required for Listen / POST /api/tts)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Optional; defaults to eleven_turbo_v2_5, auto-retries eleven_multilingual_v2 on 400/404/422
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.redreemer.app

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=

# Google Places API
GOOGLE_PLACES_API_KEY=

# Feature 2: Phone hashing salt (generate a strong random string)
PHONE_SALT=your-random-salt-here

# Feature 10: Base URL for Twilio signature validation (your ngrok or production URL)
BASE_URL=https://your-ngrok-or-domain.com

# Environment (development skips Twilio signature validation)
NODE_ENV=development
