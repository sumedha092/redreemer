# API origin for production or non-default ports. In dev, http://localhost:3001 (or unset) uses
# Vite proxy for /api, /sms, /audio, /clips — same-origin, no CORS issues for audio.
VITE_API_URL=http://localhost:3001

# Dev only: where Vite proxies /api, /audio, /clips, /sms (default http://localhost:3001).
# API_PROXY_TARGET=http://localhost:3001

# Auth0 SPA: domain is hostname ONLY (e.g. dev-abc123.us.auth0.com) — no https://
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
# Optional API audience; omit if you do not use an API identifier in Auth0
VITE_AUTH0_AUDIENCE=

# true = always use mock login (no Auth0). In dev, mock is also used if domain/client are empty.
VITE_MOCK_MODE=false
