# API: local dev — leave empty (Vite proxies /api → localhost:3001).
# Vercel + ngrok — same-origin proxy: VITE_API_URL=/api/p
#   Set Vercel env API_UPSTREAM_ORIGIN=https://….ngrok-free.app (origin only, no /api path).
# Vercel project: Root Directory = repository root OR redreemer-UI (both layouts are supported; see repo vercel.json).
# Full HTTPS API (Railway, etc.): VITE_API_URL=https://api.example.com
VITE_API_URL=
VITE_MOCK_MODE=false
# Tenant hostname only, no https://, no trailing slash or spaces (spaces break issuer validation).
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# Auth0 → Application → Settings: Allowed Callback URLs must include
# https://YOUR-DOMAIN/callback for each origin (production, previews, localhost + port).
# Allowed Logout URLs: same origins (path optional).
